#!/bin/bash
# Launcher for P!NG Serial Generator
# Avoids the broken system Python 3.9 / Tk 8.5 that crashes on macOS 15+.
# Prefers Homebrew Python (arm64 then Intel) which ships with a working Tk.

SCRIPT_DIR="$(cd "$(dirname "$0")/../Resources" && pwd)"
KEY_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"

# Find a Python that isn't the broken Xcode Command Line Tools one
PYTHON=""
for CANDIDATE in /opt/homebrew/bin/python3 /usr/local/bin/python3; do
    if [ -x "$CANDIDATE" ]; then
        PYTHON="$CANDIDATE"
        break
    fi
done

if [ -z "$PYTHON" ]; then
    osascript -e 'display dialog "P!NG Serial Generator needs Homebrew Python (the built-in macOS Python 3.9 has a broken Tk on Apple Silicon).\n\nInstall it by running this in Terminal:\n\n  brew install python-tk\n\nThen try again." with title "Python Not Found" buttons {"OK"} default button 1'
    exit 1
fi

# Check the cryptography library is available — auto-install if missing
if ! "$PYTHON" -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey" 2>/dev/null; then
    osascript -e 'display dialog "Installing the required cryptography library — this will take a few seconds…" with title "P!NG Serial Generator" buttons {"OK"} default button 1'
    "$PYTHON" -m pip install cryptography --break-system-packages --quiet
    # Verify it worked
    if ! "$PYTHON" -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey" 2>/dev/null; then
        osascript -e "display dialog \"Could not install the cryptography library automatically.\n\nPlease run this in Terminal, then try again:\n\n  $PYTHON -m pip install cryptography --break-system-packages\" with title \"Install Failed\" buttons {\"OK\"} default button 1"
        exit 1
    fi
fi

# Run with the Tools folder as working directory so the key is found
cd "$KEY_DIR"
exec "$PYTHON" "$SCRIPT_DIR/serial_generator.py"
